# Build artifacts
.build/
.swiftpm/
build/
*.xcodeproj/
*.xcworkspace/
xcuserdata/

# SPM resolved (regenerated on swift build; commit if you want reproducible dep versions)
Package.resolved

# macOS
.DS_Store

# Local agent / IDE state (machine-specific, never commit)
.claude/
.codex/
.vscode/
.idea/
.serena/

# Distribution artifacts
*.dmg
*.zip
# generated by `make publish` (uploaded to the GitHub Release); must be
# ignored or the leftover file trips publish's clean-tree guard next time
checksums-*.txt

# Local config / secrets
config.toml
config.local.toml
*.env
.env*

# Test artifacts
.test-output/

# graphify knowledge graph (generated, AST-only)
graphify-out/
